# EasyGo backend — Phase 1 (Path C)
# Copy to .env and fill in. Never commit the real .env.

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (Postgres) ---
# Example local: postgresql://easygo:easygo@localhost:5432/easygo?schema=public
DATABASE_URL=

# --- Privy (auth + embedded wallet) ---
# Get from https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Squid (cross-chain swap) ---
# Phase 1 chain target: Base (chainId 8453)
SQUID_INTEGRATOR_ID=
SQUID_API_URL=https://apiplus.squidrouter.com

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Webhook URL (prod). Leave empty in dev to use long-poll.
TELEGRAM_WEBHOOK_URL=
# Random string used as path component to gate webhook hits.
TELEGRAM_WEBHOOK_SECRET=

# --- Internal admin (server-trusted earn endpoint) ---
ADMIN_SECRET=

# --- Phase 2 (deferred) ---
# Activated only when PHASE.EASYCHAIN_ENABLED flips true in utils/easygo.js.
# Leave blank in Phase 1.
EASYCHAIN_RPC_URL=
EASYCHAIN_CHAIN_ID=
