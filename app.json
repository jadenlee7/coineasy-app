{
  "expo": {
    "name": "CoinEasy",
    "slug": "coineasy_app",
    "scheme": "coineasyapp",
    "owner": "useorbis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_christmas.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash_christmas.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "buildNumber": "37",
      "bundleIdentifier": "com.coineasy.coineasysocial"
    },
    "android": {
      "versionCode": 15,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon_christmas.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "googleServicesFile": "./google-services.json",
      "package": "com.coineasy.coineasy"
    },
    "web": {
      "favicon": "./assets/favicon_christmas.png"
    },
    "plugins": [
      [
        "expo-apple-authentication"
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "92489131-f028-4eb8-96ef-453311e899ec"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/92489131-f028-4eb8-96ef-453311e899ec"
    }
  }
}
