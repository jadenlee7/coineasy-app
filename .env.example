# .env.example — EasyGo Phase 1 environment template
# Copy to .env (gitignored) and fill in values as Aurora / Squid / Privy / Telegram respond.
# See EASYGO_BUILD_PLAN.md §12 for context.

# ---------------------------------------------------------------------------
# EasyChain (Aurora-based app-chain)
# Populated when Aurora Cloud delivers chain config (see §13.1)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_EASYCHAIN_CHAIN_ID=
EXPO_PUBLIC_EASYCHAIN_RPC_URL=
EXPO_PUBLIC_EASYCHAIN_EXPLORER_URL=
EXPO_PUBLIC_EASYCHAIN_NATIVE_SYMBOL=ETH
EXPO_PUBLIC_EASYCHAIN_PROFILE_REGISTRY=

# ---------------------------------------------------------------------------
# Squid Router (Phase 1 cross-chain rail; Lazy Liquidity)
# Populated when Squid team delivers integrator ID (see §13.2)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SQUID_INTEGRATOR_ID=
EXPO_PUBLIC_SQUID_API_URL=https://apiplus.squidrouter.com

# ---------------------------------------------------------------------------
# Privy (embedded wallet + auth)
# Set up at https://dashboard.privy.io
# ---------------------------------------------------------------------------
EXPO_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# (server-side only — DO NOT expose to client)

# ---------------------------------------------------------------------------
# Telegram Bot (growth + auth + notifications)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_TG_BOT_USERNAME=
EXPO_PUBLIC_TG_WEBAPP_URL=
TG_BOT_TOKEN=
# (server-side only — DO NOT expose to client)

# ---------------------------------------------------------------------------
# EasyGo Backend (Orange ledger + notify fanout)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_BACKEND_URL=
