# .env.example — EasyGo Phase 1 environment template
# Path C decision: Phase 1 ships on Base. EasyChain is Phase 2 (gated).
# Copy to .env (gitignored) and fill in values as Squid / Privy / Telegram respond.
# See EASYGO_BUILD_PLAN.md §3.0 (Path C) and §12.

# ---------------------------------------------------------------------------
# Phase 1 chain — Base (L2)
# Public RPCs are fine for early dev; switch to Alchemy / Infura for production
# ---------------------------------------------------------------------------
EXPO_PUBLIC_BASE_CHAIN_ID=8453
EXPO_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
EXPO_PUBLIC_BASE_EXPLORER_URL=https://basescan.org

# ---------------------------------------------------------------------------
# Squid Router (Phase 1 cross-chain rail on Base)
# Populated when Squid team delivers integrator ID (see §13.2)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SQUID_INTEGRATOR_ID=
EXPO_PUBLIC_SQUID_API_URL=https://apiplus.squidrouter.com

# ---------------------------------------------------------------------------
# Privy (embedded wallet + auth + Telegram/Kakao social ID surface)
# Set up at https://dashboard.privy.io
# ---------------------------------------------------------------------------
EXPO_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# (server-side only — DO NOT expose to client)

# ---------------------------------------------------------------------------
# Telegram Bot (growth + auth + notifications)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_TG_BOT_USERNAME=
EXPO_PUBLIC_TG_WEBAPP_URL=
TG_BOT_TOKEN=
# (server-side only — DO NOT expose to client)

# ---------------------------------------------------------------------------
# EasyGo Backend (identity DB + 🍊 Orange ledger + notify fanout)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_BACKEND_URL=

# ===========================================================================
# Phase 2 (deferred) — EasyChain on Aurora
# Activated only when PHASE.EASYCHAIN_ENABLED flips to true (see utils/easygo.js)
# Populated when Aurora delivers chain config; until then, leave empty.
# ===========================================================================
EXPO_PUBLIC_EASYCHAIN_CHAIN_ID=
EXPO_PUBLIC_EASYCHAIN_RPC_URL=
EXPO_PUBLIC_EASYCHAIN_EXPLORER_URL=
EXPO_PUBLIC_EASYCHAIN_NATIVE_SYMBOL=ETH
EXPO_PUBLIC_EASYCHAIN_PROFILE_REGISTRY=
